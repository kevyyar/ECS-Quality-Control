# Staging deployment example. Do not commit real secrets.
# Configure these values in the Vercel Preview/Staging environment.

NEXT_PUBLIC_APP_URL=https://ecs-qc-staging.example.com
NEXT_PUBLIC_SUPABASE_URL=https://replace-with-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-staging-service-role-key
DATABASE_URL=postgresql://replace-with-staging-db-url
